# ---- Self-hosted Supabase (supabase.kishankanejiiya.tech) ----
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.kishankanejiiya.tech
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER commit or expose. Used by scripts/import-games.mjs to bulk-insert.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Licensed game feeds (free publisher signup) ----
# GamePix Games Feed API sid (https://www.gamepix.com/) — optional, has a public demo feed
GAMEPIX_SID=
# GameDistribution / GameMonetize feed URL (from your publisher dashboard) — optional
GAMEDISTRIBUTION_FEED_URL=

# ---- AdSense ----
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# ---- Google Tag Manager (optional) ----
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ---- Google Analytics 4 (gtag.js, optional) ----
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ---- OneSignal web push (onesignal.com → Settings → Keys & IDs, optional) ----
NEXT_PUBLIC_ONESIGNAL_APP_ID=
